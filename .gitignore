# Keep folder placeholders if needed
!legacy/khushal_reference/data/.gitkeep
!legacy/khushal_reference/models/.gitkeep
!legacy/khushal_reference/logs/.gitkeep
!legacy/khushal_reference/results/.gitkeep

# Legacy Khushal notebooks - keep locally only, avoid heavy old experiments in public repo
legacy/khushal_reference/notebooks/*
!legacy/khushal_reference/notebooks/.gitkeep

