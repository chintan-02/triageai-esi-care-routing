# TriageAI / SympDirect backend demo configuration
# Copy this file to .env for local development if needed.
# Do not commit real .env files.

APP_NAME=TriageAI
APP_ENV=demo
DEMO_MODE=true
LOG_LEVEL=INFO
DEBUG=false

# Local development/demo database
DATABASE_URL=sqlite:///./triageai.db

# Backend service
TRIAGEAI_BACKEND_URL=http://127.0.0.1:8001

# Demo authentication placeholder only
JWT_SECRET_KEY=change-me-for-local-demo-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Final LightGBM V2 model registry
MODEL_REGISTRY_DIR=model_registry/esi_345_lightgbm_v2
MODEL_DEPLOYMENT_CONFIG=model_registry/esi_345_lightgbm_v2/esi_345_deployment_config.json
MODEL_PATH=model_registry/esi_345_lightgbm_v2/esi_345_lightgbm_v2_model.txt
PREPROCESSOR_PATH=model_registry/esi_345_lightgbm_v2/esi_345_lightgbm_v2_preprocessing_artifacts.joblib
THRESHOLDS_PATH=model_registry/esi_345_lightgbm_v2/esi_345_lightgbm_v2_threshold_config.json
FEATURE_SCHEMA_PATH=model_registry/esi_345_lightgbm_v2/esi_345_lightgbm_v2_feature_list.json
MODEL_METADATA_PATH=model_registry/esi_345_lightgbm_v2/esi_345_deployment_config.json
LABEL_MAPPING_PATH=model_registry/esi_345_lightgbm_v2/esi_345_label_mapping.json

# Generated report output
REPORT_OUTPUT_DIR=reports/generated

# Optional integrations are intentionally blank in the example.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
