FROM node:20-alpine

ENV NODE_ENV=development

WORKDIR /app/app/frontend/react_app

COPY app/frontend/react_app/package.json ./
COPY app/frontend/react_app/package-lock.json ./

RUN corepack enable \
    && corepack prepare pnpm@9.15.9 --activate \
    && pnpm install --no-frozen-lockfile

COPY app/frontend/react_app ./

EXPOSE 5173

CMD ["pnpm", "run", "dev"]
